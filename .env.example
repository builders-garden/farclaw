# HTTP port for local/dev server.
PORT=8080

# One-time setup/admin password for initial configuration.
SETUP_PASSWORD=secret

# Persistent app state directory.
OPENCLAW_STATE_DIR=/data/.openclaw

# Workspace used by the orchestrator/runtime.
OPENCLAW_WORKSPACE_DIR=/data/workspace-orchestrator

# Optional internal gateway auth token (leave blank if unused).
OPENCLAW_GATEWAY_TOKEN=

# Display name used by the project/agent.
PROJECT_NAME=My Content Team

# Farcaster handle without leading @ (e.g. alice).
FARCASTER_HANDLE=

# Farcaster numeric FID for the account.
FARCASTER_FID=

# Target Farcaster channel ID/slug.
FARCASTER_CHANNEL_ID=

# Primary LLM in provider/model format.
PRIMARY_MODEL=openrouter/moonshotai/kimi-k2.5

# Fallback LLM used when primary is unavailable.
FALLBACK_MODEL=openrouter/anthropic/claude-haiku-4.5

# API key for OpenRouter.
OPENROUTER_API_KEY=

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Optional Telegram user ID allowlist (single ID).
TELEGRAM_ALLOWED_USER_ID=

# API key for Neynar (Farcaster API provider).
NEYNAR_API_KEY=

# Neynar signer UUID for posting/signing actions.
NEYNAR_SIGNER_UUID=

# Public Railway domain for this deployment.
RAILWAY_DOMAIN=
